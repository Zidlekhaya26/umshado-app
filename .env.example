# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URL ─────────────────────────────────────────────────────────────────
# Full URL of the deployed app — used for PayFast callbacks, invite links, review links
NEXT_PUBLIC_APP_URL=https://umshado.co.za

# ─── PayFast Payments ────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=false

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@umshado.co.za

# ─── Sentry Error Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─── Anthropic AI (Ami wedding assistant) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Cron / Internal API ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-secret

# ─── Admin ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAILS=admin@umshado.co.za

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_BETA_INVITE_ONLY=false

# ─── Upstash Redis (optional — falls back to in-memory rate limiting) ────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
